#!/bin/bash
export PATH=$PATH:/usr/local/bin
set -e

# Build the image
docker build -t php-backend-common-php84 -f docker/php84/Dockerfile .

# Setup network and valkey
NET="test-net-84"
VALKEY="valkey-84"
docker network create $NET 2>/dev/null || true
docker run -d --name $VALKEY --network $NET --network-alias valkey --rm valkey/valkey:8.1-alpine

# Ensure cleanup
# shellcheck disable=SC2064
trap "docker stop $VALKEY >/dev/null 2>&1 || true; docker network rm $NET >/dev/null 2>&1 || true" EXIT

# Run the container
docker run --rm --network $NET php-backend-common-php84
